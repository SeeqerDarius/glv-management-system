{
  "name": "glv-management-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/with-database-url.cjs prisma migrate deploy && node scripts/with-database-url.cjs prisma generate && node scripts/with-database-url.cjs next build",
